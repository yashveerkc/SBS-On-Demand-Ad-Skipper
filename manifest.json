{
"manifest_version": 3,

"name": "SBS Ad Skipper",

"version": "1.0.0",

"description": "Automatically fast-forwards ad breaks on SBS On Demand on-demand content.",

"permissions": [
"storage"
],

"host_permissions": [
"*://*.sbs.com.au/*"
],

"content_scripts": [
{
"matches": [
"*://*.sbs.com.au/ondemand/*"
],
"js": [
"content.js"
],
"run_at": "document_idle"
}
],

"action": {
"default_popup": "popup.html"
},

"icons": {
"16": "icons/icon16.png",
"32": "icons/icon32.png",
"48": "icons/icon48.png",
"128": "icons/icon128.png"
}
}
